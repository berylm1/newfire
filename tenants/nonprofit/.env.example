# Nonprofit Tenant Environment Configuration
# Copy to .env and fill in real values

# LLM Configuration (via shared llm_config.py)
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=your-api-key
LLM_MODEL=glm4:9b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://host.docker.internal:11434/api/embed

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=nonprofit_tenant

# Service URLs
RAG_SERVICE_URL=http://host.docker.internal:8006
NOTIFY_SERVICE_URL=http://localhost:8008

# Qdrant Vector Store
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Grant Scout specific
GRANT_SOURCES=usaspending,grantsgov
GRANT_REFRESH_HOURS=24
