# Test Environment Configuration
# Copy this file to .env and update values as needed

# Backend API URL (where the backend is running)
TEST_API_URL=http://localhost:3200

# Test Database Configuration
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=newfire_test

# JWT Secret for testing (use a different secret than production)
JWT_SECRET=test-jwt-secret-for-testing-only-do-not-use-in-production

# Enable verbose logging (uncomment to enable)
# TEST_VERBOSE=1