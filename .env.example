# ==============================================================================
# NewFire Legal Services — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ==============================================================================

# --- LLM Routing (shared across all tenant services) ---
# Points to LiteLLM gateway. Fall back to ollama only if LiteLLM is unavailable.
LLM_BASE_URL=http://localhost:4000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemma4-26b-64k

# --- Vision model (for document processing) ---
OLLAMA_VISION_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava

# --- Embeddings (for RAG) ---
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- Service-to-Service URLs (adjust ports for your deployment) ---
ACTIVITY_LOG_SERVICE_URL=http://localhost:8001
CONFLICTS_SERVICE_URL=http://localhost:8002
RAG_SERVICE_URL=http://localhost:8003
APPROVAL_SERVICE_URL=http://localhost:8004
WEBHOOK_SERVICE_URL=http://localhost:8005
MEMORY_SERVICE_URL=http://localhost:8006
CASE_SERVICE_URL=http://localhost:8007
NOTIFY_SERVICE_URL=http://localhost:8008

# --- Qdrant (vector store) ---
QDRANT_URL=http://localhost:6333
RAG_COLLECTION=legal_documents

# --- External APIs ---
COURTLISTENER_API_TOKEN=

# --- Backend (newfire-backend Node.js service) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=newfire
DB_PASSWORD=change-me
DB_NAME=newfire
OPENROUTER_KEY=
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=
APISIX_ADMIN_URL=http://localhost:9180
APISIX_ADMIN_KEY=
JWT_SECRET=change-me-to-a-random-string
PORT=3200
NODE_ENV=production

# --- Client Rate Limits ---
CLIENT_RATE_LIMIT_RPS=20
CLIENT_RATE_LIMIT_BURST=40
CLIENT_DAILY_QUOTA=1000

# --- Qdrant API Key (if auth is enabled) ---
QDRANT_API_KEY=

# --- Onboarding model ---
ONBOARDING_MODEL=glm4:9b

# --- Embed model ---
EMBED_MODEL=nomic-embed-text

# --- RAG top-k ---
RAG_TOP_K=3

# --- SMTP (for notify_service production deployment) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- WhatsApp Business API (for notify_service production deployment) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Tenant Configuration Path ---
TENANT_CONFIG_PATH=tenants/legal/daily_briefing/tenant_config.py

# --- Webhook Secrets Path ---
WEBHOOK_SECRETS_PATH=webhook_secrets.json
