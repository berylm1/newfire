{
  "name": "@newfire/server-config",
  "version": "1.0.0",
  "description": "Security configurations for NewFire backend",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint ."
  },
  "keywords": [
    "security",
    "cors",
    "rate-limiting",
    "express",
    "middleware"
  ],
  "author": "NewFire Team",
  "license": "MIT",
  "devDependencies": {
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.js",
      "!node_modules/**"
    ],
    "testRegex": "test_.*\\.js$"
  }
}
